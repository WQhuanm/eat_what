<wxs src="./addDish.wxs" module="tools" />
<view class="container">
  <view class="card">
    <text class="section-title">🍳 提交菜品信息</text>

    <view class="form-item">
      <text class="form-label">菜品名称 *</text>
      <input class="form-input" placeholder="如：麻婆豆腐" value="{{form.name}}" bindinput="onInput" data-field="name" />
    </view>

    <!-- 关联店铺 -->
    <view class="form-item">
      <text class="form-label">所属店铺</text>
      <picker bindchange="onShopChange" value="{{shopIndex}}" range="{{shopNames}}">
        <view class="form-input picker-val">{{shopNames[shopIndex] || '请选择店铺（可选）'}}</view>
      </picker>
      <text class="link-text" bindtap="goAddShop">+ 新建店铺</text>
    </view>

    <view class="form-item">
      <text class="form-label">菜系</text>
      <picker bindchange="onCuisineChange" value="{{cuisineIndex}}" range="{{cuisineOptions}}">
        <view class="form-input picker-val">{{cuisineOptions[cuisineIndex] || '请选择菜系'}}</view>
      </picker>
    </view>

    <view class="form-item">
      <text class="form-label">口味标签</text>
      <view class="tag-group">
        <view wx:for="{{tasteOptions}}" wx:key="*this"
          class="tag-item {{tools.isSelected(form.taste_tags, item) ? 'selected' : ''}}"
          bindtap="toggleTaste" data-val="{{item}}">{{item}}</view>
      </view>
    </view>

    <view class="form-item">
      <text class="form-label">价格 (元)</text>
      <input class="form-input" type="digit" placeholder="如：28.5" value="{{form.price}}" bindinput="onInput" data-field="price" />
    </view>

    <view class="form-item">
      <text class="form-label">主要食材 (逗号分隔)</text>
      <input class="form-input" placeholder="如：豆腐,猪肉,辣椒" value="{{ingredientsText}}" bindinput="onIngredientsInput" />
    </view>

    <view class="form-item">
      <text class="form-label">口味描述</text>
      <textarea class="form-input" style="height:150rpx" placeholder="描述菜品口味特点..." value="{{form.description}}" bindinput="onInput" data-field="description" />
    </view>

    <!-- 图片上传 -->
    <view class="form-item">
      <text class="form-label">宣传图片（支持URL或本地上传）</text>
      <view class="img-upload-area">
        <view class="img-preview" wx:for="{{previewImages}}" wx:key="*this">
          <image src="{{item}}" mode="aspectFill" />
          <view class="img-delete" catchtap="removeImage" data-index="{{index}}">×</view>
        </view>
        <view class="img-add" bindtap="chooseImage" wx:if="{{previewImages.length < 3}}">
          <text>+</text>
        </view>
      </view>
    </view>

    <button class="btn-primary" style="margin-top:30rpx" bindtap="submitDish" loading="{{submitting}}">提交菜品（审核后展示）</button>
  </view>
</view>
