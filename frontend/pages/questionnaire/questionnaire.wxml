<wxs src="./questionnaire.wxs" module="tools" />
<view class="container">
  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>
  <text class="progress-text">{{currentIndex + 1}} / {{questions.length}}</text>

  <!-- 当前问题 -->
  <view class="card question-card" wx:if="{{questions.length > 0}}">
    <text class="question-text">{{questions[currentIndex].question_text}}</text>

    <view class="options-list">
      <view wx:if="{{questions[currentIndex].question_type === 'scale'}}" class="scale-box">
        <slider
          min="{{questions[currentIndex].min_value || 0}}"
          max="{{questions[currentIndex].max_value || 5}}"
          step="{{questions[currentIndex].step || 1}}"
          value="{{selectedMap[questions[currentIndex].question_key] ? selectedMap[questions[currentIndex].question_key][0] : 0}}"
          show-value="true"
          data-key="{{questions[currentIndex].question_key}}"
          bindchange="onScaleChange"
        />
      </view>

      <view wx:if="{{questions[currentIndex].question_type === 'text'}}" class="text-box">
        <textarea
          class="form-input"
          placeholder="请输入特殊需求（可选）"
          value="{{selectedMap[questions[currentIndex].question_key] ? selectedMap[questions[currentIndex].question_key][0] : ''}}"
          data-key="{{questions[currentIndex].question_key}}"
          bindinput="onTextInput"
          maxlength="120"
        />
      </view>

      <view
        wx:if="{{questions[currentIndex].question_type !== 'scale' && questions[currentIndex].question_type !== 'text'}}"
        wx:for="{{questions[currentIndex].options}}"
        wx:key="*this"
        class="option-item {{tools.isSelected(selectedMap, questions[currentIndex].question_key, item) ? 'selected' : ''}}"
        bindtap="selectOption"
        data-key="{{questions[currentIndex].question_key}}"
        data-value="{{item}}"
        data-multi="{{questions[currentIndex].multi_select ? 1 : 0}}"
      >
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="btn-group">
    <button class="btn-secondary" bindtap="prevQuestion" wx:if="{{currentIndex > 0}}">上一题</button>
    <button class="btn-primary" bindtap="nextQuestion" wx:if="{{currentIndex < questions.length - 1}}">下一题</button>
    <button class="btn-primary" bindtap="submitAnswers" wx:if="{{currentIndex === questions.length - 1}}" loading="{{submitting}}">提交，看看推荐</button>
  </view>
</view>
