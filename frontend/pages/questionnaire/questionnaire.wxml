<wxs src="./questionnaire.wxs" module="tools" />
<view class="container">
  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>
  <text class="progress-text">{{currentIndex + 1}} / {{questions.length}}</text>

  <!-- 当前问题 -->
  <view class="card question-card" wx:if="{{questions.length > 0}}">
    <text class="question-text">{{questions[currentIndex].question_text}}</text>

    <view class="options-list">
      <view
        wx:for="{{questions[currentIndex].options}}"
        wx:key="*this"
        class="option-item {{tools.isSelected(selectedMap, questions[currentIndex].question_key, item) ? 'selected' : ''}}"
        bindtap="selectOption"
        data-key="{{questions[currentIndex].question_key}}"
        data-value="{{item}}"
        data-multi="{{questions[currentIndex].multi_select ? 1 : 0}}"
      >
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="btn-group">
    <button class="btn-secondary" bindtap="prevQuestion" wx:if="{{currentIndex > 0}}">上一题</button>
    <button class="btn-primary" bindtap="nextQuestion" wx:if="{{currentIndex < questions.length - 1}}">下一题</button>
    <button class="btn-primary" bindtap="submitAnswers" wx:if="{{currentIndex === questions.length - 1}}" loading="{{submitting}}">提交，看看推荐</button>
  </view>
</view>
