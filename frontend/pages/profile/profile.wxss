.user-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx;
}
.avatar-emoji { font-size: 100rpx; }
.user-name {
  font-size: 36rpx;
  font-weight: bold;
  margin-top: 16rpx;
}
.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 30rpx;
}
.menu-icon { font-size: 40rpx; margin-right: 20rpx; }
.menu-text { flex: 1; font-size: 30rpx; }
.menu-arrow { font-size: 36rpx; color: #ccc; }
.logout .menu-text { color: #e74c3c; }
