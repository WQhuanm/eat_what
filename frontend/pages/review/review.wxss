.review-list {
  margin-top: 20rpx;
}
.review-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
}
.item-name {
  font-size: 28rpx;
  font-weight: bold;
}
.item-type {
  font-size: 24rpx;
  color: #999;
}
.review-actions {
  display: flex;
  gap: 16rpx;
}
.review-page {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
  color: #333;
}
.empty {
  text-align: center;
  color: #999;
  margin-top: 200rpx;
  font-size: 30rpx;
}
.review-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}
.review-info {
  display: flex;
  flex-direction: column;
}
.review-name {
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
}
.review-type {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  display: inline-block;
  width: fit-content;
}
.tag-dish {
  background: #fff3e0;
  color: #ff9800;
}
.tag-shop {
  background: #e3f2fd;
  color: #2196f3;
}
