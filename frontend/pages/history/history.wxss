.empty-tip {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}
.history-item { padding: 24rpx 30rpx; }
.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.history-dish { font-size: 32rpx; font-weight: bold; }
.history-tag {
  font-size: 22rpx;
  background: #4CAF50;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}
.history-time {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}
.load-more {
  text-align: center;
  padding: 30rpx;
  color: #FF6B35;
  font-size: 28rpx;
}
.history-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}
.reselect-btn {
  font-size: 24rpx;
  color: #FF6B35;
  border: 2rpx solid #FF6B35;
  border-radius: 24rpx;
  padding: 8rpx 24rpx;
}
