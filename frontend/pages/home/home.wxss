.home-page {
  padding: 40rpx 30rpx;
}
.hero-area {
  text-align: center;
  padding: 80rpx 0 60rpx;
}
.hero-emoji {
  font-size: 120rpx;
  display: block;
}
.hero-title {
  font-size: 52rpx;
  font-weight: bold;
  display: block;
  margin-top: 20rpx;
}
.hero-desc {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}
.hero-location {
  display: block;
  margin-top: 14rpx;
  color: #7d7d7d;
  font-size: 24rpx;
}
.action-area { margin: 40rpx 0; }
.big-btn {
  font-size: 36rpx !important;
  padding: 30rpx 0 !important;
}
.btn-secondary {
  background-color: #FF6B35;
  color: #fff;
  border-radius: 50rpx;
  border: none;
}
.btn-secondary::after { border: none; }
.tip-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 2;
}
